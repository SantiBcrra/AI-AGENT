# ── Base de datos ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:1234@localhost:5432/analytics_db
DATABASE_SSL=false

# ── Redis (local en tu servidor) ───────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Anthropic (Claude API) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (para GSC y Gmail) ───────────────────────
# Obtener en: https://console.cloud.google.com/apis/credentials
# Tipo: "ID de cliente de OAuth 2.0" → Aplicación web
# Redirect URI autorizado: https://tudominio.com/api/auth/gsc/callback
# (en local: http://localhost:3000/api/auth/gsc/callback)
# APIs que debes habilitar en tu proyecto de Google Cloud:
#   - Google Search Console API
#   - Google Webmasters API (misma cosa, distinto nombre)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gmail (cron 03 — parsear emails de avisos GSC) ──────────
# Requiere un refresh_token OAuth con scope gmail.readonly.
# El flujo /api/auth/gsc/connect solo pide webmasters; para Gmail obtén el token
# aparte (p. ej. OAuth 2.0 Playground con el mismo Client ID) y pégalo aquí.
# GMAIL_REFRESH_TOKEN=1//0...

# ── MaxMind GeoLite2 (cron 06 — actualizar BBDD GeoIP) ───────
# Cuenta gratuita: https://www.maxmind.com/en/geolite2/signup
# MAXMIND_LICENSE_KEY=tu_clave

# ── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL=https://stats.tudominio.com
NEXTAUTH_SECRET=genera_con__openssl_rand_base64_32

# ── App ────────────────────────────────────────────────────
NODE_ENV=production

# ── GHL Agent ─────────────────────────────────────────────
# Los API keys de GHL se almacenan POR SITIO en la tabla ghl_sites.
# Para registrar un sitio en el agente, ejecuta en PostgreSQL:
#
#   INSERT INTO ghl_sites (site_id, location_id, api_key, dry_run)
#   VALUES (
#     <id del site en la tabla sites>,
#     '<GHL Location ID>',       -- Settings → Business Info → Location ID
#     '<GHL API Key>',           -- Settings → API Keys → Create Key (Full Access)
#     true                       -- Cambiar a false cuando estés listo para aplicar cambios reales
#   );
#
# Donde obtener las credenciales GHL:
#   Location ID: GHL → Settings → Business Info → Location ID
#   API Key:     GHL → Settings → API Keys → Create new key (tipo: Full Access)
#   Docs API:    https://highlevel.stoplight.io/docs/integrations/
#
# Límites del agente (configurables por sitio):
#   max_changes_per_day:  max cambios automáticos por día (default: 5)
#   max_changes_per_page: max cambios por página por semana (default: 2)
#   cooldown_hours:       horas entre cambios en la misma página (default: 24)
#
# ── Email: digest de diagnósticos del agente (post-diagnosePages) ──
# AGENT_DIAGNOSTIC_NOTIFY_TO=santiariel1705@gmail.com
# Opcional: solo enviar si hay al menos una página con issues (default: true)
# AGENT_DIAGNOSTIC_EMAIL_ONLY_IF_ISSUES=false
#
# Remitente (obligatorio para cualquier transporte)
# AGENT_EMAIL_FROM="Analytics Agent <noreply@tudominio.com>"
#
# Opción A — Resend (https://resend.com): dominio verificado
# RESEND_API_KEY=re_...
#
# Opción B — SMTP (ej. Gmail con contraseña de aplicación)
# AGENT_SMTP_HOST=smtp.gmail.com
# AGENT_SMTP_PORT=587
# AGENT_SMTP_SECURE=false
# AGENT_SMTP_USER=tu@gmail.com
# AGENT_SMTP_PASS=xxxx_app_password
